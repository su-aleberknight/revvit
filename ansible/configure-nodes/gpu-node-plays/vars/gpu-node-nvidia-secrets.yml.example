---
# NVIDIA NGC (nvcr.io) — always created
# Username is always '$oauthtoken' — password is your NGC API key.
# Generate an API key at https://ngc.nvidia.com under API keys.
nvidia_registry:
  username: "$oauthtoken"
  password: "your-ngc-api-key"
  secret_name: "nvidia-registry-secret"
  namespace: "gpu-operator"

# SUSE Application Collections (registry.suse.com) — optional
# Uncomment to also create the AppCo secret for the operator-managed NVIDIA driver image.
# suse_appco:
#   username: "your-appco-email@example.com"
#   password: "your-appco-account-token"
#   secret_name: "suse-appco-secret"
#   namespace: "gpu-operator"
