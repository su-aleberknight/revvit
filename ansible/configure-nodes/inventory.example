# Ansible inventory for RKE2 HA cluster
# Copy to 'inventory' and fill in your node IPs and hostnames.
#
# Usage:
#   cp inventory.example inventory
#   ansible-playbook run-rke2-ha-plays.yml -i inventory

[rke2_bootstrap]
node1 ansible_host=192.168.1.10 ansible_user=root

[rke2-leader-node]
node1 ansible_host=192.168.1.10 ansible_user=root

[rke2-server-nodes]
node1 ansible_host=192.168.1.10 ansible_user=root
node2 ansible_host=192.168.1.11 ansible_user=root
node3 ansible_host=192.168.1.12 ansible_user=root

# Worker nodes are optional — leave this group empty or remove it if not needed
[rke2-agent-nodes]
worker1 ansible_host=192.168.1.20 ansible_user=root
worker2 ansible_host=192.168.1.21 ansible_user=root

# GPU nodes — add any nodes that have GPUs (used by gpu-node-nvidia-* playbooks)
[rke2-gpu-nodes]
worker1 ansible_host=192.168.1.20 ansible_user=root

[vip]
vip ansible_host=192.168.1.100 ansible_user=root
