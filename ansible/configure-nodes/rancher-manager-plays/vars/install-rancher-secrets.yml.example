---
# Credentials for SUSE Application Collections OCI registry.
# Username is your SUSE account email.
# Password is your SCC registration code (not the AppCo account token).
rancher_appco_repo:
  name: "suse-application-collections"
  url: "oci://registry.suse.com/application-collections/charts"
  username: "your-scc-email@example.com"
  password: "your-scc-registration-code"
  secret_name: "suse-appco-rancher-secret"

# Credentials for the SUSE Registry Server OCI registry.
rancher_suse_registry_repo:
  name: "suse-registry"
  url: "oci://registry.suse.com"
  username: "your-scc-email@example.com"
  password: "your-scc-registration-code"
  secret_name: "suse-registry-rancher-secret"
