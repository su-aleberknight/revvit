---
# Longhorn Helm chart repository URL
lh_helm_repo_url: "https://charts.longhorn.io"

# Longhorn UI ingress hostname
lh_url: "longhorn.example.com"

# Longhorn UI basic auth credentials
lh_user: "admin"
lh_password: "longhorn"

# Default replica count for Longhorn volumes
lh_default_replica_count: 1

# Default replica count for the default StorageClass
lh_default_class_replica_count: 1

# Replica count for CSI components (attacher, provisioner, resizer, snapshotter)
lh_csi_replica_count: 1

# Percentage of disk space reserved for the default disk
lh_reserved_disk_percentage: 15

# Filesystem type for the default StorageClass
lh_default_sc_fs_type: "ext4"

# Additional StorageClasses to create. Each entry is a dict with keys:
#   name:        StorageClass name
#   fs_type:     Filesystem type (e.g. ext4, xfs)
#   num_replicas: Number of replicas (default: 3)
#
# Example:
# lh_additional_storageclasses:
#   - name: longhorn-xfs
#     fs_type: xfs
#     num_replicas: 3
#   - name: longhorn-ext4-2rep
#     fs_type: ext4
#     num_replicas: 2
lh_additional_storageclasses: []

# Set to true to create a nginx-based Ingress for the Longhorn UI
lh_create_ingress: false
