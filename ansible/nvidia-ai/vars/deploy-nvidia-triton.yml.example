---
# NVIDIA Triton Inference Server deployment vars.
# Note: ngc_api_key, nvidia_ai_namespace, ngc_pull_secret_name, storage_class_name
# are defined in vars/nvidia-global.yml

# Triton chart version. Leave empty for latest.
triton_version: ""

# Triton ingress hostname
triton_ingress_host: "triton.example.com"

# Triton container image tag (from nvcr.io/nvidia/tritonserver)
triton_image_tag: "25.03-py3"

# Model repository — path to PVC or S3 URI
# For PVC: use triton_model_pvc_size below
# For S3:  triton_model_repository: "s3://mybucket/models"
triton_model_repository: "/models"

# Persistent volume size for model repository (set to "" to disable PVC)
triton_model_pvc_size: "50Gi"

# Backends to enable
triton_backend_onnxruntime: true
triton_backend_tensorrt: true
triton_backend_pytorch: true
triton_backend_tensorflow: false

# GPU resource count
triton_gpu_count: 1

# RuntimeClass for GPU workloads
triton_runtimeclassname: "nvidia"

# Replica count
triton_replicas: 1
