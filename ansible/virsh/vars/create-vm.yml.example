---
# ISO to install from
vm_iso: "/home/aleberkn/isos/SLES-16.0-Full-x86_64-GM.install.iso"

# CPU, memory, and disk — applied to all VMs
vm_vcpus: 20
vm_memory_mb: 51200       # 50 GB in MB
vm_disk_size: 100          # GB
vm_disk_path: "/var/lib/libvirt/images"

# Networking — 'default' uses the NAT network (virbr0)
# Use a bridge name (e.g. br0) for bridged/direct network access
vm_network: "default"

# Graphics — vnc for remote console, spice for local desktop
vm_graphics: "vnc"

# OS variant — used by libvirt to apply OS-specific optimisations
# Run 'osinfo-query os' to list available variants
vm_os_variant: "sles15sp6"

# Inventory group to create VMs for — defaults to 'all'
# vm_group: "homelab-vm-servers"
